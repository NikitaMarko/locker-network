NODE_ENV=development
PORT=3555
SERVER_URL=http://localhost:3555
FRONTEND_LOCAL_URL=http://localhost:5173
FRONTEND_URL=
CLOUDFRONT_URL=
LOG_LEVEL=info

DATABASE_URL="postgresql://root:root@localhost:5433/locker"

# Optional: set when testing Google Sign-In locally
GOOGLE_CLIENT_ID=

JWT_ACCESS_SECRET=super-secret-key-for-access-jwt-token
JWT_REFRESH_SECRET=super-secret-key-for-refresh-jwt-token
JWT_ACCESS_EXPIRES_IN=15m
JWT_ACCESS_TOKEN_TTL=15
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_TTL=7

USE_LAMBDA_HEALTH=false
LAMBDA_HEALTH_URL=

AWS_REGION=eu-west-1
# Optional if you use profile/role-based auth outside LocalStack
AWS_PROFILE=
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
DYNAMO_ROLE_ARN=
DYNAMO_ROLE_SESSION_NAME=locker-backend-dynamo
SQS_ROLE_ARN=
SQS_ROLE_SESSION_NAME=locker-backend-sqs
DYNAMODB_ENDPOINT_URL=http://localhost:4566
SQS_ENDPOINT_URL=http://localhost:4566
REDIS_URL=redis://localhost:6379
REDIS_STATION_CACHE_PREFIX=station-cache:
REDIS_STATION_CACHE_TTL_SECONDS=300

DYNAMO_TABLE_NAME=locker-dev-operations-dynamodb
DYNAMO_LOCKER_CACHE_TABLE_NAME=locker-dev-locker-cache

OPERATIONS_QUEUE_URL=http://sqs.eu-west-1.localhost.localstack.cloud:4566/000000000000/locker-operations-queue
CACHE_PROJECTION_QUEUE_URL=http://sqs.eu-west-1.localhost.localstack.cloud:4566/000000000000/locker-dev-cache-projection
SQS_URL=http://sqs.eu-west-1.localhost.localstack.cloud:4566/000000000000/locker-operations-queue
