generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  OPERATOR
  ADMIN
}

enum StationStatus {
  READY
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum LockerSize {
  S
  M
  L
}

enum LockerStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  FAULTY
  EXPIRED
}

enum BookingStatus {
  PENDING
  ACTIVE
  ENDED
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ErrorSeverity {
  INFO
  WARN
  ERROR
  CRITICAL
}

enum IdempotencyRecordStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  userId   String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  phone    String? @unique
  role     Role    @default(USER)

  passwordChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  bookings  Booking[]
  sessions  RefreshSession[]
  auditLogs AuditLog[]       @relation("AuditActor")
}

model RefreshSession {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  tokenHash String

  ipAddress  String?
  deviceInfo String?

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model City {
  cityId String @id @default(uuid())

  code String @unique // TLV
  name String // Tel Aviv

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stations LockerStation[]
  Pricing  Pricing[]
}

model LockerStation {
  stationId String                                 @id @default(uuid())
  cityId    String
  city      City                                   @relation(fields: [cityId], references: [cityId])
  address   String? // "Dizengoff 10"
  latitude  Float
  longitude Float
  location  Unsupported("geography(Point, 4326)")?
  status    StationStatus                          @default(INACTIVE)
  version   Int                                    @default(0)
  createdAt DateTime                               @default(now())
  updatedAt DateTime                               @updatedAt

  lockers  LockerBox[]
  bookings Booking[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([cityId, status, isDeleted])
}

model LockerBox {
  lockerBoxId String @id @default(uuid())

  stationId String
  station   LockerStation @relation(fields: [stationId], references: [stationId], onDelete: Cascade)

  code String // "A-01"
  size LockerSize

  status  LockerStatus @default(AVAILABLE)
  version Int          @default(0)

  lastStatusChangedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  device LockerDevice?

  statusHistory LockerStatusHistory[]

  auditLog AuditLog[]
  bookings Booking[]  @relation("LockerBookings")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([stationId, code])
  @@index([stationId])
  @@index([status])
  @@index([stationId, status])
}

model Pricing {
  priceId String @id @default(uuid())

  cityId String
  city   City       @relation(fields: [cityId], references: [cityId])
  size   LockerSize

  pricePerHour Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, size])
  @@index([cityId])
}

enum DeviceOnlineStatus {
  ONLINE
  OFFLINE
}

enum DoorStatus {
  OPEN
  CLOSED
}

enum LockStatus {
  LOCKED
  UNLOCKED
}

model LockerDevice {
  deviceId String @id @default(uuid())

  lockerBoxId String    @unique
  lockerBox   LockerBox @relation(fields: [lockerBoxId], references: [lockerBoxId], onDelete: Cascade)

  onlineStatus DeviceOnlineStatus @default(ONLINE)
  doorStatus   DoorStatus         @default(CLOSED)
  lockStatus   LockStatus         @default(LOCKED)

  lastHeartbeat DateTime?
  firmware      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  bookingId String @id @unique @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Restrict)

  lockerBoxId String
  lockerBox   LockerBox @relation("LockerBookings", fields: [lockerBoxId], references: [lockerBoxId])

  stationId String
  station   LockerStation @relation(fields: [stationId], references: [stationId], onDelete: Restrict)

  status BookingStatus @default(PENDING)

  startTime       DateTime?
  expectedEndTime DateTime?
  endTime         DateTime?

  totalPrice Decimal? @db.Decimal(10, 2)

  idempotencyKey String? @unique

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lockerBoxId])
  @@index([userId])
  @@index([stationId])
  @@index([status])
}

model LockerStatusHistory {
  id String @id @default(uuid())

  lockerBoxId String
  lockerBox   LockerBox @relation(fields: [lockerBoxId], references: [lockerBoxId], onDelete: Restrict)

  fromStatus LockerStatus?
  toStatus   LockerStatus

  reason String
  source String

  bookingId String?

  createdAt DateTime @default(now())

  @@index([lockerBoxId, createdAt])
}

model Payment {
  paymentId String @id @default(uuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [bookingId], onDelete: Restrict)

  status PaymentStatus

  provider          String?
  providerPaymentId String?

  amount   Decimal
  currency String

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  lockerId   String?
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  actor  User?      @relation("AuditActor", fields: [actorId], references: [userId], onDelete: SetNull)
  locker LockerBox? @relation(fields: [lockerId], references: [lockerBoxId], onDelete: SetNull)

  @@index([actorId])
  @@index([lockerId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model IdempotencyRecord {
  recordId           String                  @id
  requestHash        String
  status             IdempotencyRecordStatus
  responseStatusCode Int?
  responseBody       Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([status, updatedAt])
}
